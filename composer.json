{
    "name": "deixtra/laravel-starter-auth",
    "license": "MIT",
    "description": "Laravel 13 auth scaffold with views, models, migrations, controllers, middleware and password reset",
    "keywords": ["laravel", "auth", "starter", "password-reset", "deixtra"],
    "homepage": "https://deixtra.com",
    "type": "library",
    "authors": [
        {
            "name": "Deixtra Private Limited",
            "email": "support@deixtra.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Deixtra\\LaravelStarterAuth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Deixtra\\LaravelStarterAuth\\AuthStarterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
